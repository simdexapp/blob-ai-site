# versaAI server config — copy to .env for local dev (.env is gitignored).
# In production, set these as service environment variables on Railway / your
# host of choice, NOT via committed .env files.

# Required — no chat without this. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — without it, voice replies fall back to the browser's built-in
# SpeechSynthesis. Get a key at https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Optional — server bind. Defaults match Railway's defaults.
# PORT=3000
# HOST=0.0.0.0
