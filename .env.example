# Set these as Cloudflare Worker secrets, not committed env files:
#   cd worker && wrangler secret put ANTHROPIC_API_KEY
#   cd worker && wrangler secret put ELEVENLABS_API_KEY   # optional
#
# ANTHROPIC_API_KEY is required — no chat without it.
# ELEVENLABS_API_KEY is optional — without it, voice replies fall back to the
# browser's built-in SpeechSynthesis (the worker returns 503 from /api/tts and
# the client retries locally).
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
